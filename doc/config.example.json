{
  "_comment": "lockd2 example config – copy to /etc/lockd2.json and fill in your values",

  "mqtt": {
    "broker":        "mqtt.example.com",
    "port":          8883,
    "username":      "bXF0dC11c2VybmFtZQ==",
    "password":      "dGlrdG9zLWplbHN6bw==",
    "ca_file":       "/etc/ssl/certs/mqtt-ca.pem",
    "client_id":     "lockd2-server",
    "topic_state":   "locks/+/state",
    "topic_batt":    "locks/+/batt",
    "topic_cmd_tpl": "locks/%s/cmd"
  },

  "http": {
    "listen":         "127.0.0.1:8884",
    "external_url":   "http://lockd.reas.hu:8089",
    "auth_file":      "/etc/lockd2/auth_keys",
    "audit_file":     "/etc/lockd2/audit.log",
    "cert_file":      "/etc/lockd2/tls/server.crt",
    "key_file":       "/etc/lockd2/tls/server.key",
    "admin_key_file": "/etc/lockd2/admin_key"
  },

  "locks": [
    {
      "id":          "frontdoor",
      "name":        "Bejárati ajtó",
      "type":        "TOGGLE",
      "has_battery": true
    },
    {
      "id":          "garage",
      "name":        "Garázs",
      "type":        "TOGGLE",
      "has_battery": true
    },
    {
      "id":          "lobby",
      "name":        "Előtér – elektromos zárpenge",
      "type":        "STRIKE",
      "has_battery": false
    },
    {
      "id":          "gate",
      "name":        "Kapu – impulzusvezérelt",
      "type":        "PULSE",
      "has_battery": false
    }
  ],

  "acl": [
    {
      "_comment": "alice hozzáfér a bejárathoz és a garázshoz",
      "user":  "alice",
      "locks": ["frontdoor", "garage"]
    },
    {
      "_comment": "bob csak az előtérhez és a kapuhoz fér hozzá",
      "user":  "bob",
      "locks": ["lobby", "gate"]
    },
    {
      "_comment": "admin mindenhez hozzáfér",
      "user":  "admin",
      "locks": ["*"]
    }
  ]
}
